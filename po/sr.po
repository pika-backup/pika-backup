#: src/ui/utils.rs:429
msgid "Pika Backup"
msgstr "Пика резерва"

#: data/app.desktop.in:6
msgid "Backups"
msgstr "Резерве"

#: data/app.desktop.in:7 data/app.metainfo.xml.in:5
msgid "Keep your data safe"
msgstr "Држите ваше поддатке на безбедном месту"

#: data/app.desktop.in:13
msgid "archive;back-up;borg;"
msgstr "архива;резерва;борг;archive;back-up;borg;"

#. developer_name tag deprecated with Appstream 1.0
