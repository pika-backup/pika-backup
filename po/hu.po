msgstr "A biztonsági mentési beállítás címe"

#: pika-backup-common/src/borg/scripts.rs:100
msgid "Repository ID of the borg repository"
msgstr "A borg tároló tárolóazonosítója"

#: pika-backup-common/src/borg/scripts.rs:101
msgid "The full URL passed to borgbackup"
msgstr "A borgbackup számára átadott teljes URL"

#. Translators: Do not translate '0' and '1' here, this is documentation
#. for possible variable values
#: pika-backup-common/src/borg/scripts.rs:105
msgid "0: manual backup, 1: started from a schedule"
msgstr "0: kézi biztonsági mentés, 1: ütemezőből indított"

#. Translators: String uses pango markup. Do not translate capslocked words
#. they are values for a variable.
#: pika-backup-common/src/borg/scripts.rs:110
msgid "Either “<tt>COMPLETED</tt>”, “<tt>ABORTED</tt>” or “<tt>FAILED</tt>”"
msgstr ""
"A következők egyike: „<tt>COMPLETED</tt>”, „<tt>ABORTED</tt>” vagy "
"„<tt>FAILED</tt>”"

#: pika-backup-common/src/borg/scripts.rs:112
msgid "An error/warning message"
msgstr "Hibaüzenet/figyelmeztetés"

#: pika-backup-common/src/borg/scripts.rs:113
msgid "The ID of the created backup archive"
msgstr "A létrehozott biztonsági mentési archívum azonosítója"

#: pika-backup-common/src/borg/scripts.rs:114
msgid "The name of the created backup archive"
msgstr "A létrehozott biztonsági mentési archívum neve"

#: pika-backup-common/src/borg/scripts.rs:116
msgid "The total amount of bytes referenced by this archive"
msgstr "Az archívum által hivatkozott bájtok teljes száma"

#: pika-backup-common/src/borg/scripts.rs:119
msgid "The compressed size of all data references by this archive"
msgstr "Az archívum által hivatkozott adatok tömörített mérete"

#: pika-backup-common/src/borg/scripts.rs:122
msgid "The deduplicated amount of bytes for this archive"
msgstr "Az archívumhoz tartozó deduplikált bájtok száma"

#: pika-backup-common/src/borg/scripts.rs:124
msgid "The amount of files saved in this archive"
msgstr "Az archívumban mentett fájlok száma"

#: pika-backup-common/src/borg/scripts.rs:276
#, rust-format
msgid ""
"The pre-backup command configured in preferences failed to run.\n"
"{}"
msgstr ""
"Nem sikerült a beállításokban megadott biztonsági mentés előtti parancs "
"futtatása.\n"
"{}"

#: pika-backup-common/src/borg/scripts.rs:280
#, rust-format
msgid ""
"The post-backup command configured in preferences failed to run.\n"
"{}"
msgstr ""
"Nem sikerült a beállításokban megadott biztonsági mentés utáni parancs "
"futtatása.\n"
"{}"

#: pika-backup-common/src/borg/scripts.rs:306
#, rust-format
msgid ""
"The pre-backup command configured in preferences returned a failure code: {}"
msgstr ""
"A beállításokban megadott biztonsági mentés előtti parancs hibakódot adott "
"vissza: {}"

#: pika-backup-common/src/borg/scripts.rs:310
#, rust-format
msgid ""
"The post-backup command configured in preferences returned a failure code: {}"
msgstr ""
"A beállításokban megadott biztonsági mentés utáni parancs hibakódot adott "
"vissza: {}"

#: pika-backup-common/src/borg/task.rs:47
msgid "Generic operation"
msgstr "Általános művelet"

#: pika-backup-common/src/borg/task.rs:61
msgid "Backing up data"
msgstr "Adatok biztonsági mentése"

#: pika-backup-common/src/borg/task.rs:75
msgid "Mounting backup archives"
msgstr "Biztonsági mentési archívumok csatolása"

