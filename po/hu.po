#: pika-backup-common/src/borg/log_json.rs:207
msgid "Calculating archive statistics"
msgstr "Archívumstatisztikák kiszámítása"

#: pika-backup-common/src/borg/log_json.rs:208
msgid "Marking old archives as deleted"
msgstr "Régi archívumok töröltnek jelölése"

#: pika-backup-common/src/borg/log_json.rs:209
msgid "Upgrading repository"
msgstr "Tároló frissítése"

#: pika-backup-common/src/borg/log_json.rs:210
msgid "Unspecified operation"
msgstr "Meghatározatlan művelet"

#: pika-backup-common/src/borg/log_json.rs:211
msgid "Unknown operation"
msgstr "Ismeretlen művelet"

#: pika-backup-common/src/borg/log_json.rs:228
msgid "Handling a Question"
msgstr "Kérdés kezelése"

#: pika-backup-common/src/borg/log_json.rs:236
msgid "Attempting to access a previously unknown unencrypted repository."
msgstr "Kísérlet egy korábban ismeretlen, titkosítatlan tároló elérésére."

#: pika-backup-common/src/borg/log_json.rs:252
#, rust-format
msgid "The backup repository at location “{}” was previously located at “{}”."
msgstr ""
"A(z) „{}” helyen lévő biztonsági mentési tároló korábban a(z) „{}” helyen "
"volt."

#: pika-backup-common/src/borg/log_json.rs:256
msgid "The backup repository was previously located at a different location."
msgstr "A biztonsági mentési tároló korábban egy eltérő helyen volt."

#: pika-backup-common/src/borg/log_json.rs:260
msgid ""
"This is a potentially dangerous function. Repairing a repository might lead "
"to data loss (for kinds of corruption it is not capable of dealing with). BE "
"VERY CAREFUL!"
msgstr ""
"Ez egy potenciálisan veszélyes funkció. Egy tároló javítása adatvesztéshez "
"vezethet (olyan típusú sérülések esetén, amelyekkel nem képes megbirkózni). "
"LEGYEN NAGYON ÓVATOS!"

#: pika-backup-common/src/borg/log_json.rs:263
msgid ""
"You requested to delete the repository completely, including all backup "
"archives it contains."
msgstr ""
"A tároló teljes törlését kérte, beleértve a benne lévő összes biztonsági "
"mentési archívumot is."

#: pika-backup-common/src/borg/log_json.rs:266
#, rust-format
msgid "Unexpected question from borgbackup: “{}”"
msgstr "Váratlan kérdés a borgbackup programtól: „{}”"

#. Translators: Combines statement from above and this question
#: pika-backup-common/src/borg/log_json.rs:271
#, rust-format
