#: pika-backup-common/src/borg/log_json.rs:203
msgid "Verifying references"
msgstr "Hivatkozások ellenőrzése"

#: pika-backup-common/src/borg/log_json.rs:204
msgid "Extracting data"
msgstr "Adatok kinyerése"

#: pika-backup-common/src/borg/log_json.rs:205
msgid "Extracting permissions"
msgstr "Jogosultságok kinyerése"

#: pika-backup-common/src/borg/log_json.rs:206
msgid "Marking archives as deleted"
