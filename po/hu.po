#: pika-backup/src/widget/dialog/preferences.ui:127
msgid "General"
msgstr "Általános"

#: data/resources/shortcuts-dialog.ui:10
msgid "Set Up New Backup"
msgstr "Új biztonsági mentés beállítása"

#: data/resources/shortcuts-dialog.ui:16
