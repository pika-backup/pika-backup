#: pika-backup/src/widget/detail/backup/display.rs:13
#: pika-backup/src/widget/detail/backup/events.rs:214
msgid "Home"
msgstr "Dossier personnel"

#: pika-backup-common/src/config/error.rs:34
msgid ""
"This archive prefix is already used by another backup configuration for the "
"same backup repository."
msgstr ""
"Ce préfixe d’archive est déjà utilisé par une autre configuration de "
"sauvegarde pour le même dépôt."

#: pika-backup-common/src/config/error.rs:41
msgid ""
"A configuration for the same backup repository with an empty archive prefix "
"exists."
msgstr ""
"Une configuration de sauvegarde pour le même dépôt avec un préfixe d’archive "
"vide existe."

#: pika-backup-common/src/config/error.rs:44
#: pika-backup-common/src/config/error.rs:54
msgid ""
"There can only be one configuration for a backup repository if the archive "
"prefix is empty."
