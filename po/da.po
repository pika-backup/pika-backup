#: pika-backup/src/widget/dialog/about.rs:11
#: pika-backup/src/widget/overview.ui:22
msgid "Pika Backup"
msgstr "Pika Backup"

#: data/app.desktop.in:6
msgid "Backups"
msgstr "Sikkerhedskopier"

#: data/app.desktop.in:7 data/app.metainfo.xml.in:5
msgid "Keep your data safe"
msgstr "Hold dine data sikre"

#: data/app.desktop.in:13
msgid "archive;back-up;borg;"
msgstr "arkivér;arkivering;sikkerhedskopiér;sikkerhedskopiering;borg;"

# https://flathub.org/apps/collection/developer/Small%20Mammal%20Collective/1
#. developer_name tag deprecated with Appstream 1.0
#. Translators: Do not translate, only transliterate if necessary
#: data/app.metainfo.xml.in:9 pika-backup/src/widget/dialog/about.rs:17
msgid "Small Mammal Collective"
msgstr "Small Mammal Collective"

#: data/app.metainfo.xml.in:29
msgid ""
"Doing backups the easy way. Plugin your USB drive and let the Pika do the "
"rest for you."
msgstr ""
"Foretag sikkerhedskopieringer på den lette måde. Sæt dit USB-drev i og lad "
"Pika gøre resten for dig."

#: data/app.metainfo.xml.in:33
msgid "Create backups locally and remotely"
msgstr "Opret sikkerhedskopier lokalt og fjernt"

#: data/app.metainfo.xml.in:34
msgid "Set a schedule for regular backups"
msgstr "Indstil en tidsplan for regelmæssige sikkerhedskopieringer"

#: data/app.metainfo.xml.in:35
msgid ""
"Save time and disk space because Pika Backup does not need to copy known "
"data again"
msgstr ""
"Spar tid og diskplads da Pika Backup ikke behøver at kopiere kendte data igen"

#: data/app.metainfo.xml.in:36
msgid "Encrypt your backups"
msgstr "Kryptér dine sikkerhedskopier"

#: data/app.metainfo.xml.in:37
msgid "List created archives and browse through their contents"
msgstr "Vis oprettede arkiver og gennemse deres indhold"

#: data/app.metainfo.xml.in:38
msgid "Recover files or folders via your file browser"
msgstr "Gendan filer eller mapper med din filvælger"

#: data/app.metainfo.xml.in:40
msgid ""
"Pika Backup is designed to save your personal data and does not support "
"complete system recovery. Pika Backup is powered by the well-tested "
"BorgBackup software."
msgstr ""
"Pika Backup er designet til at gemme dine personlige data og understøtter "
"ikke fuldstændig gendannelse af systemet. Pika Backup bruger det "
"gennemtestede program BorgBackup."

#: data/app.metainfo.xml.in:65
msgid "Just activate “Back Up Now” and your data will be saved"
msgstr "Aktivér “Sikkerhedskopiér nu”, og dine data vil blive gemt"

#: data/app.metainfo.xml.in:69
msgid "Keep backups on local drives and at online services at the same time"
msgstr "Opbevar sikkerhedskopier på lokale drev og på onlinetjenester samtidig"

#: data/app.metainfo.xml.in:73
msgid "Schedule regular backups from monthly up to hourly"
msgstr "Planlæg regelmæssige sikkerhedskopieringer fra timevis til månedligt"

