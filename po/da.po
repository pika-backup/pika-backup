msgid "Home"
msgstr "Hjem"

#: pika-backup-common/src/config/error.rs:34
msgid ""
"This archive prefix is already used by another backup configuration for the "
"same backup repository."
msgstr ""
"Dette arkivpræfiks bruges allerede af en anden sikkerhedskopikonfiguration "
"til det samme sikkerhedskopiopbevaringssted."

#: pika-backup-common/src/config/error.rs:41
msgid ""
